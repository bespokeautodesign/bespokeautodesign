{
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
